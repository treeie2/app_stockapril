# ============================================
# WeChat Fetch Research - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Primary API (火山引擎)
PRIMARY_API_KEY=your_volces_api_key_here
PRIMARY_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
PRIMARY_MODEL=deepseek-v3-2-251201

# Fallback API (SiliconFlow)
FALLBACK_API_KEY=your_siliconflow_api_key_here
FALLBACK_BASE_URL=https://api.siliconflow.cn/v1
FALLBACK_MODEL=Qwen/Qwen2.5-72B-Instruct

# Firebase (place credentials file at secrets/firebase-credentials.json)
# No env var needed, just mount the file

# GitHub
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=yourusername/yourrepo

# Logging
LOG_LEVEL=INFO

# Optional: Custom paths
# DATA_DIR=/app/data
# RAW_MATERIAL_DIR=/app/raw_material

# ============================================
# Cloudflare R2 (用于 raw_material 云端存储)
# 获取方式: https://dash.cloudflare.com/ -> R2 -> Manage R2 API Tokens
# ============================================
R2_ACCOUNT_ID=c302e6962b93a5e883dc7188da9466e9
R2_ACCESS_KEY_ID=82d0d9920ff1640a47b2a4be0d270e6e
R2_SECRET_ACCESS_KEY=1f74b0c370d7d87b6626f4b67069d55b5f0092aa59733604d57cc501275cfbec
R2_BUCKET_NAME=stock-research
